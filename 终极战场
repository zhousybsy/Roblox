-- 轴输入框（带 +5 / -5 三角按钮）
local function makeAxisInput(labelText, axis, posY)
    local row = Instance.new("Frame")
    row.Size = UDim2.new(1, -24, 0, 32)
    row.Position = UDim2.new(0, 12, 0, posY)
    row.BackgroundTransparency = 1
    row.Parent = panel

    -- 标签
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0, 52, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = labelText
    label.TextColor3 = Color3.fromRGB(180, 180, 220)
    label.Font = Enum.Font.GothamBold
    label.TextSize = 13
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = row

    -- 往下按钮 ▼（紧贴标签右边）
    local downBtn = Instance.new("TextButton")
    downBtn.Size             = UDim2.new(0, 26, 1, -4)
    downBtn.Position         = UDim2.new(0, 54, 0, 2)
    downBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 55)
    downBtn.Text             = "▼"
    downBtn.TextColor3       = Color3.fromRGB(160, 160, 220)
    downBtn.Font             = Enum.Font.GothamBold
    downBtn.TextSize         = 11
    downBtn.BorderSizePixel  = 0
    downBtn.AutoButtonColor  = false
    downBtn.Parent           = row
    Instance.new("UICorner", downBtn).CornerRadius = UDim.new(0, 6)

    -- 输入框（中间）
    local box = Instance.new("TextBox")
    box.Size = UDim2.new(1, -140, 1, -4)
    box.Position = UDim2.new(0, 84, 0, 2)
    box.BackgroundColor3 = Color3.fromRGB(35, 35, 50)
    box.Text = tostring(S.Cfg[axis])
    box.TextColor3 = Color3.fromRGB(220, 220, 255)
    box.Font = Enum.Font.Gotham
    box.TextSize = 13
    box.BorderSizePixel = 0
    box.ClearTextOnFocus = false
    box.Parent = row
    Instance.new("UICorner", box).CornerRadius = UDim.new(0, 8)
    local boxStroke = Instance.new("UIStroke", box)
    boxStroke.Color = Color3.fromRGB(90, 90, 130); boxStroke.Thickness = 1.2; boxStroke.Transparency = 0.4

    -- 往上按钮 ▲（输入框右边）
    local upBtn = Instance.new("TextButton")
    upBtn.Size             = UDim2.new(0, 26, 1, -4)
    upBtn.Position         = UDim2.new(1, -28, 0, 2)
    upBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 55)
    upBtn.Text             = "▲"
    upBtn.TextColor3       = Color3.fromRGB(160, 160, 220)
    upBtn.Font             = Enum.Font.GothamBold
    upBtn.TextSize         = 11
    upBtn.BorderSizePixel  = 0
    upBtn.AutoButtonColor  = false
    upBtn.Parent           = row
    Instance.new("UICorner", upBtn).CornerRadius = UDim.new(0, 6)

    -- 通用：更新数值并刷新显示
    local function applyValue(v)
        S.Cfg[axis] = math.clamp(v, 10, 150)
        box.Text = tostring(S.Cfg[axis])
        if enabled then S:ToggleHitbox(true) end
    end

    -- 输入框焦点高亮
    box.Focused:Connect(function()
        TweenService:Create(boxStroke, TweenInfo.new(0.1), { Transparency = 0 }):Play()
    end)
    box.FocusLost:Connect(function()
        TweenService:Create(boxStroke, TweenInfo.new(0.1), { Transparency = 0.4 }):Play()
        local v = tonumber(box.Text)
        if v then applyValue(v) else box.Text = tostring(S.Cfg[axis]) end
    end)

    -- +5 / -5 按钮
    upBtn.MouseButton1Click:Connect(function()
        applyValue(S.Cfg[axis] + 5)
        TweenService:Create(upBtn, TweenInfo.new(0.08), { BackgroundColor3 = Color3.fromRGB(60, 60, 100) }):Play()
        task.delay(0.15, function()
            TweenService:Create(upBtn, TweenInfo.new(0.08), { BackgroundColor3 = Color3.fromRGB(35, 35, 55) }):Play()
        end)
    end)
    downBtn.MouseButton1Click:Connect(function()
        applyValue(S.Cfg[axis] - 5)
        TweenService:Create(downBtn, TweenInfo.new(0.08), { BackgroundColor3 = Color3.fromRGB(60, 60, 100) }):Play()
        task.delay(0.15, function()
            TweenService:Create(downBtn, TweenInfo.new(0.08), { BackgroundColor3 = Color3.fromRGB(35, 35, 55) }):Play()
        end)
    end)
end

