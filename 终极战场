            panel.Visible = false
            bubble.Visible = true
            TweenService:Create(bubble, TweenInfo.new(0.15, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
                BackgroundTransparency = 0.05
            }):Play()
        end)
