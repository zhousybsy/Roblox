        -- 从小方块展开回面板
        bubble.Visible = false
        panel.Position = UDim2.new(
            bubble.Position.X.Scale, bubble.Position.X.Offset,
            bubble.Position.Y.Scale, bubble.Position.Y.Offset
        )
        panel.Visible = true
        panel.BackgroundTransparency = 1
        local targetH = isCollapsed and PANEL_H_CLOSED or PANEL_H_OPEN
        TweenService:Create(panel, TweenInfo.new(0.2, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, 240, 0, targetH),
            BackgroundTransparency = 0.05,
